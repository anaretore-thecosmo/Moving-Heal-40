{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user anamnesis and settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "age": { "type": "integer" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "location": { "type": "string" },
        "fitnessLevel": { "type": "string" },
        "trainingHistory": { "type": "string" },
        "regularGymInPast": { "type": "boolean" },
        "personalTrainerExp": { "type": "boolean" },
        "techniqueConfidence": { "type": "string", "enum": ["yes", "no", "some"] },
        "neglectedMuscles": { "type": "array", "items": { "type": "string" } },
        "avoidedEquipment": { "type": "string" },
        "reasonForAvoiding": { "type": "array", "items": { "type": "string" } },
        "pains": { "type": "array", "items": { "type": "string" } },
        "painIntensity": { "type": "string" },
        "painTriggers": { "type": "array", "items": { "type": "string" } },
        "forbiddenExercises": { "type": "string" },
        "pastInjuries": { "type": "string" },
        "limitations": { "type": "string" },
        "posturePatterns": { "type": "array", "items": { "type": "string" } },
        "mobilityLevel": { "type": "string" },
        "stabilityLevel": { "type": "string" },
        "abdominalState": { "type": "string" },
        "objectives": { "type": "array", "items": { "type": "string" } },
        "subjectiveGoals": { "type": "array", "items": { "type": "string" } },
        "fatAccumulation": { "type": "array", "items": { "type": "string" } },
        "stubbornFat": { "type": "string" },
        "weightGainSign": { "type": "string" },
        "easyMuscleGain": { "type": "array", "items": { "type": "string" } },
        "hardMuscleGain": { "type": "array", "items": { "type": "string" } },
        "availableEquipment": { "type": "array", "items": { "type": "string" } },
        "weeklyFrequency": { "type": "integer" },
        "sessionDuration": { "type": "integer" },
        "environment": { "type": "string", "enum": ["gym", "home", "both"] },
        "planTypePreference": { "type": "string", "enum": ["fixed", "modular", "dynamic", "ai_choice"] },
        "fcmToken": { "type": "string", "description": "FCM registration token for web push" },
        "fcmEnabled": { "type": "boolean", "description": "User notification approval status" },
        "reminderMinutesBefore": { "type": "integer", "description": "Pre-workout delay in minutes for reminder" },
        "scheduledNotificationTime": { "type": "string", "description": "Calculated or manual notification time" },
        "consistencyDaysCount": { "type": "integer" },
        "habitualWorkoutTime": { "type": "string", "description": "Mapped daily average workout start hour" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "Workout": {
      "title": "Workout Program",
      "description": "Personalized training program generated by AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "archived"] },
        "days": {
          "type": "array",
          "items": { $ref: "WorkoutDay" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Session": {
      "title": "Workout Session",
      "description": "Log of a specific workout session including check-in and detailed history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "workoutId": { "type": "string" },
        "dayIndex": { "type": "integer" },
        "energyLevel": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "painToday": { "type": "string" },
        "painLocation": { "type": "array", "items": { "type": "string" } },
        "durationMinutes": { "type": "integer" },
        "actualDurationMinutes": { "type": "integer" },
        "location": { "type": "string" },
        "intent": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "isCompleted": { "type": "boolean" },
        "rating": { "type": "string" },
        "satisfactionScore": { "type": "integer" },
        "effortScore": { "type": "integer" },
        "isBored": { "type": "boolean" },
        "painLevel": { "type": "integer" },
        "feltWhere": { "type": "array", "items": { "type": "string" } },
        "exercisesToAvoid": { "type": "string" },
        "exercisesLiked": { "type": "string" },
        "exerciseFeedback": { "type": "string" },
        "logs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "exerciseId": { "type": "string" },
              "name": { "type": "string" },
              "skipped": { "type": "boolean" },
              "sets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "reps": { "type": "integer" },
                    "weight": { "type": "number" },
                    "rpe": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "Evolution": {
      "title": "Evolution Record",
      "description": "Historical records of measurements and performance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["weight", "measurement", "performance"] },
        "category": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "category", "value", "unit"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "users/{userId}/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "History of generated workouts"
    },
    "users/{userId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Logs of completed sessions"
    },
    "users/{userId}/evolution/{evolutionId}": {
      "schema": "Evolution",
      "description": "Progress tracking records"
    }
  }
}
